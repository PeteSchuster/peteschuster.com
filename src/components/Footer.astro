---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <p>&copy; {year} Pete Schuster</p>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
